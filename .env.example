# AWS RDS PostgreSQL connection string for Prisma
# Replace host/user/password/db values with your stack outputs.
DATABASE_URL="postgresql://utransit_admin:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/utransit?schema=public&sslmode=require"

